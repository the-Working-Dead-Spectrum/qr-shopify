# -----------------------------------------------------------------------
# Variables à ajouter dans votre .env existant
# -----------------------------------------------------------------------

APP_NAME=qr-shopify
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

# PWA Configuration
PWA_NAME="QR Shopify Scanner"
PWA_SHORT_NAME="QR Scanner"
PWA_START_URL="/pwa/scan"
PWA_DISPLAY="standalone"
PWA_BACKGROUND_COLOR="#0A2164"
PWA_THEME_COLOR="#1B56F5"
PWA_ORIENTATION="portrait"
PWA_CACHE_ENABLED=true
PWA_CACHE_STRATEGY="networkFirst"

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug


SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Clé HMAC dédiée QR Code — OBLIGATOIRE, distincte de APP_KEY
# Générer avec : openssl rand -base64 32
APP_QR_SECRET=

# Shopify webhook secret — copier depuis Dashboard Shopify > Paramètres > Webhooks
SHOPIFY_WEBHOOK_SECRET=

# Alertes admin
ADMIN_EMAIL=admin@app.com

# Configuration QR Code (optionnel — valeurs par défaut indiquées)
QR_TTL_DAYS=7
QR_SIZE_PX=400
QR_CLEANUP_DAYS=180
QR_ALERT_THRESHOLD=10

# -----------------------------------------------------------------------
# À modifier par rapport aux défauts Laravel
# -----------------------------------------------------------------------

# Base de données — passer de sqlite à mysql en production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qr_app
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8
DB_COLLATION=utf8_unicode_ci

# Queue — database en dev, redis en production
QUEUE_CONNECTION=database

# Cache — file en dev, redis en production
CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false


BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Redis (production uniquement)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sentry (production uniquement)
SENTRY_LARAVEL_DSN=
